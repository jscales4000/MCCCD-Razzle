{
  "name": "MCCCD-AA140",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node build.mjs",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "archive": "npm run build && ch5-cli archive -p MCCCD-AA140 -d dist -o output",
    "deploy": "npm run archive && python scripts/deploy.py",
    "deploy:tabletop": "npm run archive && cross-env PANEL_HOST=192.168.2.53 python scripts/deploy.py",
    "deploy:wall": "npm run archive && cross-env PANEL_HOST=192.168.2.123 python scripts/deploy.py",
    "clean": "rimraf dist output",
    "verify-signals": "rg -n \"AA140\\.\" src --glob \"*.ts\" --glob \"*.svelte\"",
    "validate": "node scripts/validate.mjs"
  },
  "devDependencies": {
    "@crestron/ch5-shell-utilities-cli": "^2.17.2",
    "@crestron/ch5-utilities-cli": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-static-copy": "^2.0.0"
  },
  "dependencies": {
    "@crestron/ch5-crcomlib": "^2.17.2",
    "@crestron/ch5-webxpanel": "^2.8.0"
  }
}
